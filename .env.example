# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where the app is hosted.
APP_URL="YOUR_APP_URL_HERE"

# SUPABASE_CONFIGURATION: Supabase credentials for persistent database tracking.
# Prefix with VITE_ so they are safely exposed to the client-side React app.
VITE_SUPABASE_URL="https://YOUR_SUPABASE_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
